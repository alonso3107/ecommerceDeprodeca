# DEPRODECA E-commerce — Variables de Entorno (ejemplo)
# Copiar a .env y ajustar valores locales
# ========================================================

# Servidor
SERVER_PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/deprodeca?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=cambiar-por-secreto-seguro
JWT_EXPIRATION_HOURS=24

# ========================================================
# Credenciales por defecto (desarrollo local)
# ========================================================
# PostgreSQL:  postgres / admin
# Admin:       admin@deprodeca.pe / admin123
